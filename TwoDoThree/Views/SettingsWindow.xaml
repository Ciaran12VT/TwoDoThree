<Window x:Class="TwoDoThree.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TwoDoThree.Converters"
        xmlns:models="clr-namespace:TwoDoThree.Models"
        Title="Settings"
        Icon="../Assets/AppIcon.ico"
        Height="520"
        Width="720"
        MinHeight="460"
        MinWidth="620"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:EmailSourceDisplayConverter x:Key="EmailSourceDisplayConverter" />

        <Style x:Key="GraphEmailSourceVisibilityStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Email.Source}" Value="{x:Static models:EmailSource.MicrosoftGraph}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ClassicEmailSourceVisibilityStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Email.Source}" Value="{x:Static models:EmailSource.ClassicOutlook}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ManualEmailSourceVisibilityStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Email.Source}" Value="{x:Static models:EmailSource.ManualImport}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InboxSyncEmailSourceVisibilityStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Email.Source}" Value="{x:Static models:EmailSource.MicrosoftGraph}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Email.Source}" Value="{x:Static models:EmailSource.ClassicOutlook}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ListBox Grid.Column="0"
                         ItemsSource="{Binding Sections}"
                         SelectedItem="{Binding SelectedSection}"
                         BorderThickness="0"
                         Background="#F9FAFB" />

                <Border Grid.Column="1"
                        BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="1,0,0,0"
                        Padding="18">
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="{x:Type Grid}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSection}" Value="Email">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Email"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,18" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Email source"
                                                   VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding EmailSourceValues}"
                                                  SelectedItem="{Binding Email.Source}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EmailSourceDisplayConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>

                                    <Border Margin="0,16,0,0"
                                            Padding="12"
                                            BorderBrush="{StaticResource MutedBorderBrush}"
                                            BorderThickness="1"
                                            Style="{StaticResource GraphEmailSourceVisibilityStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="158" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.ColumnSpan="2"
                                                       Text="Microsoft Graph / Entra"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,10" />

                                            <TextBlock Grid.Row="1"
                                                       Text="Account address"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding Email.AccountAddress, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBlock Grid.Row="2"
                                                       Text="Tenant ID"
                                                       Margin="0,10,0,0"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Margin="0,10,0,0"
                                                     Text="{Binding Email.TenantId, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBlock Grid.Row="3"
                                                       Text="Client ID"
                                                       Margin="0,10,0,0"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="3"
                                                     Grid.Column="1"
                                                     Margin="0,10,0,0"
                                                     Text="{Binding Email.ClientId, UpdateSourceTrigger=PropertyChanged}" />

                                            <CheckBox Grid.Row="4"
                                                      Grid.Column="1"
                                                      Margin="0,12,0,0"
                                                      Content="Use Windows authentication"
                                                      IsChecked="{Binding Email.UseWindowsAuthentication}" />
                                        </Grid>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Padding="12"
                                            BorderBrush="{StaticResource MutedBorderBrush}"
                                            BorderThickness="1"
                                            Style="{StaticResource ClassicEmailSourceVisibilityStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Classic Outlook"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       Text="Uses the local default Classic Outlook profile. No Microsoft Graph or Entra fields are required."
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Padding="12"
                                            BorderBrush="{StaticResource MutedBorderBrush}"
                                            BorderThickness="1"
                                            Style="{StaticResource InboxSyncEmailSourceVisibilityStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="158" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.ColumnSpan="2"
                                                       Text="Inbox sync"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,10" />

                                            <TextBlock Grid.Row="1"
                                                       Text="Sync interval"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Row="1"
                                                        Grid.Column="1"
                                                        Orientation="Horizontal">
                                                <TextBox Width="80"
                                                         Text="{Binding Email.SyncIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text=" minutes"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <TextBlock Grid.Row="2"
                                                       Text="Max inbox emails"
                                                       Margin="0,10,0,0"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Width="80"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,10,0,0"
                                                     Text="{Binding Email.MaxInboxMessages, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Padding="12"
                                            BorderBrush="{StaticResource MutedBorderBrush}"
                                            BorderThickness="1"
                                            Style="{StaticResource ManualEmailSourceVisibilityStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Manual import"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       Text="Import .eml or .msg files from the main Email panel. No connection settings are required."
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="0,14,0,0"
                                                Orientation="Horizontal"
                                                Style="{StaticResource GraphEmailSourceVisibilityStyle}">
                                        <Button Width="84"
                                                Content="Connect"
                                                Click="ConnectButton_Click" />
                                        <Button Width="112"
                                                Margin="8,0,0,0"
                                                Content="Test Connection"
                                                Click="TestConnectionButton_Click" />
                                        <Button Width="92"
                                                Margin="8,0,0,0"
                                                Content="Disconnect"
                                                Click="DisconnectButton_Click" />
                                    </StackPanel>

                                    <StackPanel Margin="0,14,0,0"
                                                Orientation="Horizontal"
                                                Style="{StaticResource ClassicEmailSourceVisibilityStyle}">
                                        <Button Width="108"
                                                Content="Check Outlook"
                                                Click="ConnectButton_Click" />
                                        <Button Width="92"
                                                Margin="8,0,0,0"
                                                Content="Test Inbox"
                                                Click="TestConnectionButton_Click" />
                                        <Button Width="92"
                                                Margin="8,0,0,0"
                                                Content="Clear Cache"
                                                Click="DisconnectButton_Click" />
                                    </StackPanel>

                                    <StackPanel Margin="0,14,0,0"
                                                Orientation="Horizontal"
                                                Style="{StaticResource ManualEmailSourceVisibilityStyle}">
                                        <Button Width="92"
                                                Content="Clear Cache"
                                                Click="DisconnectButton_Click" />
                                    </StackPanel>

                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding ConnectionStatus}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="{x:Type Grid}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSection}" Value="Tags">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Tags"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18" />

                            <DockPanel Grid.Row="1"
                                       Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right"
                                        Width="84"
                                        Margin="8,0,0,0"
                                        Content="Add"
                                        Command="{Binding TagManager.AddTagCommand}" />
                                <TextBox Text="{Binding TagManager.NewTag, UpdateSourceTrigger=PropertyChanged}"
                                         MinWidth="220" />
                            </DockPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ListBox ItemsSource="{Binding TagManager.Tags}"
                                         SelectedItem="{Binding TagManager.SelectedTag}" />
                                <Button Grid.Column="1"
                                        Width="92"
                                        Height="28"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Top"
                                        Content="Remove"
                                        Command="{Binding TagManager.RemoveTagCommand}" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="84"
                    Content="Cancel"
                    Click="CancelButton_Click" />
            <Button Width="84"
                    Margin="8,0,0,0"
                    Content="Save"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
