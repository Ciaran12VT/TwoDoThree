<Window x:Class="TwoDoThree.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TwoDoThree.Converters"
        Title="Settings"
        Icon="../Assets/AppIcon.ico"
        Height="520"
        Width="720"
        MinHeight="460"
        MinWidth="620"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:EmailSourceDisplayConverter x:Key="EmailSourceDisplayConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ListBox Grid.Column="0"
                         ItemsSource="{Binding Sections}"
                         SelectedItem="{Binding SelectedSection}"
                         BorderThickness="0"
                         Background="#F9FAFB" />

                <Border Grid.Column="1"
                        BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="1,0,0,0"
                        Padding="18">
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="{x:Type Grid}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSection}" Value="Email">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.ColumnSpan="2"
                                       Text="Email"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18" />

                            <TextBlock Grid.Row="1"
                                       Text="Email source"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      ItemsSource="{Binding EmailSourceValues}"
                                      SelectedItem="{Binding Email.Source}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EmailSourceDisplayConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="2"
                                       Text="Account address"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="0,10,0,0"
                                     Text="{Binding Email.AccountAddress, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="3"
                                       Text="Display name"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="0,10,0,0"
                                     Text="{Binding Email.DisplayName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="4"
                                       Text="Tenant ID"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Row="4"
                                     Grid.Column="1"
                                     Margin="0,10,0,0"
                                     Text="{Binding Email.TenantId, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="5"
                                       Text="Client ID"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Row="5"
                                     Grid.Column="1"
                                     Margin="0,10,0,0"
                                     Text="{Binding Email.ClientId, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="6"
                                       Text="Sync interval"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Row="6"
                                        Grid.Column="1"
                                        Margin="0,10,0,0"
                                        Orientation="Horizontal">
                                <TextBox Width="80"
                                         Text="{Binding Email.SyncIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text=" minutes"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Grid.Row="7"
                                       Text="Max inbox emails"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Row="7"
                                     Grid.Column="1"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     Margin="0,10,0,0"
                                     Text="{Binding Email.MaxInboxMessages, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox Grid.Row="8"
                                      Grid.Column="1"
                                      Margin="0,12,0,0"
                                      Content="Use Windows authentication"
                                      IsChecked="{Binding Email.UseWindowsAuthentication}" />

                            <StackPanel Grid.Row="9"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="0,14,0,0">
                                <Button Width="84"
                                        Content="Connect"
                                        Click="ConnectButton_Click" />
                                <Button Width="112"
                                        Margin="8,0,0,0"
                                        Content="Test Connection"
                                        Click="TestConnectionButton_Click" />
                                <Button Width="92"
                                        Margin="8,0,0,0"
                                        Content="Disconnect"
                                        Click="DisconnectButton_Click" />
                            </StackPanel>

                            <TextBlock Grid.Row="10"
                                       Grid.Column="1"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding ConnectionStatus}"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="{x:Type Grid}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSection}" Value="Tags">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Tags"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18" />

                            <DockPanel Grid.Row="1"
                                       Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right"
                                        Width="84"
                                        Margin="8,0,0,0"
                                        Content="Add"
                                        Command="{Binding TagManager.AddTagCommand}" />
                                <TextBox Text="{Binding TagManager.NewTag, UpdateSourceTrigger=PropertyChanged}"
                                         MinWidth="220" />
                            </DockPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ListBox ItemsSource="{Binding TagManager.Tags}"
                                         SelectedItem="{Binding TagManager.SelectedTag}" />
                                <Button Grid.Column="1"
                                        Width="92"
                                        Height="28"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Top"
                                        Content="Remove"
                                        Command="{Binding TagManager.RemoveTagCommand}" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="84"
                    Content="Cancel"
                    Click="CancelButton_Click" />
            <Button Width="84"
                    Margin="8,0,0,0"
                    Content="Save"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
