<Window x:Class="TwoDoThree.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Icon="../Assets/AppIcon.ico"
        Height="430"
        Width="720"
        MinHeight="360"
        MinWidth="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ListBox Grid.Column="0"
                         ItemsSource="{Binding Sections}"
                         SelectedItem="{Binding SelectedSection}"
                         BorderThickness="0"
                         Background="#F9FAFB" />

                <Border Grid.Column="1"
                        BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="1,0,0,0"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2"
                                   Text="Email"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,18" />

                        <TextBlock Grid.Row="1"
                                   Text="Account address"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding Email.AccountAddress, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Text="Display name"
                                   Margin="0,10,0,0"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="0,10,0,0"
                                 Text="{Binding Email.DisplayName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3"
                                   Text="Tenant ID"
                                   Margin="0,10,0,0"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Margin="0,10,0,0"
                                 Text="{Binding Email.TenantId, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4"
                                   Text="Client ID"
                                   Margin="0,10,0,0"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Margin="0,10,0,0"
                                 Text="{Binding Email.ClientId, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="5"
                                   Text="Sync interval"
                                   Margin="0,10,0,0"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Row="5"
                                    Grid.Column="1"
                                    Margin="0,10,0,0"
                                    Orientation="Horizontal">
                            <TextBox Width="80"
                                     Text="{Binding Email.SyncIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text=" minutes"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <CheckBox Grid.Row="6"
                                  Grid.Column="1"
                                  Margin="0,12,0,0"
                                  Content="Use Windows authentication"
                                  IsChecked="{Binding Email.UseWindowsAuthentication}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="84"
                    Content="Cancel"
                    Click="CancelButton_Click" />
            <Button Width="84"
                    Margin="8,0,0,0"
                    Content="Save"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
