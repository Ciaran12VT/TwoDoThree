<Window x:Class="TwoDoThree.Views.ResourcePopoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TwoDoThree.Controls"
        Title="Resource"
        Icon="../Assets/AppIcon.ico"
        Height="680"
        Width="920"
        MinHeight="420"
        MinWidth="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Resource.Name, RelativeSource={RelativeSource AncestorType=Window}}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,12" />

        <Border Grid.Row="1"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1"
                Background="#FFFFFF"
                Padding="10">
            <controls:ResourceViewerControl Resource="{Binding Resource, RelativeSource={RelativeSource AncestorType=Window}}" />
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="84"
                    Content="Close"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
