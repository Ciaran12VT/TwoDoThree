<Window x:Class="TwoDoThree.Views.TaskDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TwoDoThree.Controls"
        xmlns:converters="clr-namespace:TwoDoThree.Converters"
        xmlns:models="clr-namespace:TwoDoThree.Models"
        Title="Task Detail"
        Height="820"
        Width="1120"
        MinHeight="680"
        MinWidth="940"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:StatusDisplayConverter x:Key="StatusDisplayConverter" />

        <Style x:Key="RoundIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#9CA3AF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EFF6FF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DBEAFE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TextResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="#FFFFFF" />
        </DataTemplate>

        <DataTemplate x:Key="CodeResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     FontFamily="Consolas"
                     FontSize="13"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="#111827"
                     Foreground="#F9FAFB" />
        </DataTemplate>

        <DataTemplate x:Key="ImageResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="1"
                        Background="#F9FAFB">
                    <Image Source="{Binding Content}" Stretch="Uniform" />
                </Border>
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="{Binding Content}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AudioResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <StackPanel>
                <TextBlock Text="{Binding Name}"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,6,0,14"
                           Text="{Binding Content}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap" />
                <MediaElement Source="{Binding Content}"
                              Height="42"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SurfResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <Border BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Background="#F9FAFB"
                    Padding="16">
                <TextBlock Text="{Binding Content}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}" />
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Title"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Text="{Binding Task.Title, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1"
                           Text="Tags"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Margin="0,10,0,0"
                         Text="{Binding Task.Tags, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2"
                           Text="Status"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <ComboBox Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,12,20,0"
                          ItemsSource="{Binding TaskStatusValues}"
                          SelectedItem="{Binding Task.Status}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource StatusDisplayConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Text="CreatedOn"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="2"
                           Grid.Column="3"
                           Margin="0,12,20,0"
                           VerticalAlignment="Center"
                           Text="{Binding Task.CreatedOn, StringFormat={}{0:g}}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="4"
                           Text="UpdatedOn"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="2"
                           Grid.Column="5"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding Task.UpdatedOn, StringFormat={}{0:g}}" />

                <TextBlock Grid.Row="3"
                           Text="Time Spent"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding Task.TimeSpent}" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Resources"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Style="{StaticResource RoundIconButtonStyle}"
                        ToolTip="Text"
                        Command="{Binding AddTextResourceCommand}">
                    <TextBlock Text="&#xE8A5;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15" />
                </Button>
                <Button Style="{StaticResource RoundIconButtonStyle}"
                        ToolTip="Code Snippet"
                        Margin="8,0,0,0"
                        Command="{Binding AddCodeResourceCommand}">
                    <TextBlock Text="&#xE943;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15" />
                </Button>
                <Button Style="{StaticResource RoundIconButtonStyle}"
                        ToolTip="Image"
                        Margin="8,0,0,0"
                        Command="{Binding AddImageResourceCommand}">
                    <TextBlock Text="&#xE91B;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15" />
                </Button>
                <Button Style="{StaticResource RoundIconButtonStyle}"
                        ToolTip="Audio"
                        Margin="8,0,0,0"
                        Command="{Binding AddAudioResourceCommand}">
                    <TextBlock Text="&#xE767;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15" />
                </Button>
                <Button Style="{StaticResource RoundIconButtonStyle}"
                        ToolTip="Surf Resource"
                        Margin="8,0,0,0"
                        Command="{Binding AddSurfResourceCommand}">
                    <TextBlock Text="&#xE774;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15" />
                </Button>
            </StackPanel>
        </DockPanel>

        <Expander Grid.Row="2"
                  Header="Resources"
                  IsExpanded="True"
                  Margin="0,0,0,12">
            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Padding="10">
                <Grid x:Name="ResourcesGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="420" />
                        <ColumnDefinition x:Name="ResourceSplitterColumn" Width="Auto" />
                        <ColumnDefinition x:Name="ResourcePaneColumn" Width="292" MinWidth="32" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{StaticResource MutedBorderBrush}"
                            BorderThickness="1"
                            Background="#FFFFFF"
                            Padding="10">
                        <ContentControl Content="{Binding SelectedResource}">
                            <ContentControl.Style>
                                <Style TargetType="{x:Type ContentControl}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource TextResourceTemplate}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedResource.Kind}" Value="{x:Static models:ResourceKind.CodeSnippet}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource CodeResourceTemplate}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedResource.Kind}" Value="{x:Static models:ResourceKind.Image}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource ImageResourceTemplate}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedResource.Kind}" Value="{x:Static models:ResourceKind.Audio}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource AudioResourceTemplate}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedResource.Kind}" Value="{x:Static models:ResourceKind.SurfResource}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource SurfResourceTemplate}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </Border>

                    <GridSplitter x:Name="ResourceGridSplitter"
                                  Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Stretch"
                                  Background="#E5E7EB" />

                    <Grid Grid.Column="2" x:Name="ResourcePane">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition x:Name="ResourceTreeColumn" Width="*" MinWidth="0" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ToggleResourceTreeButton"
                                Content=">"
                                Width="26"
                                Margin="3,0"
                                Padding="0"
                                VerticalAlignment="Stretch"
                                Click="ToggleResourceTreeButton_Click" />

                        <Border Grid.Column="1"
                                x:Name="ResourceTreePanel"
                                BorderBrush="{StaticResource MutedBorderBrush}"
                                BorderThickness="1"
                                Background="#FFFFFF">
                            <TreeView x:Name="ResourceTree"
                                      ItemsSource="{Binding ResourceGroups}"
                                      SelectedItemChanged="ResourceTree_SelectedItemChanged"
                                      BorderThickness="0">
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type models:ResourceGroup}" ItemsSource="{Binding Resources}">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    </HierarchicalDataTemplate>
                                    <DataTemplate DataType="{x:Type models:ResourceItem}">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </TreeView.Resources>
                            </TreeView>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Expander>

        <Border Grid.Row="3"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1"
                Padding="10">
            <controls:ActionListControl />
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="84"
                    Content="Close"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
