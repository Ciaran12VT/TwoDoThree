<Window x:Class="TwoDoThree.Views.TaskDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TwoDoThree.Controls"
        xmlns:models="clr-namespace:TwoDoThree.Models"
        Title="Task Detail"
        Height="820"
        Width="1120"
        MinHeight="680"
        MinWidth="940"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <DataTemplate x:Key="TextResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="#FFFFFF" />
        </DataTemplate>

        <DataTemplate x:Key="CodeResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     FontFamily="Consolas"
                     FontSize="13"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="#111827"
                     Foreground="#F9FAFB" />
        </DataTemplate>

        <DataTemplate x:Key="ImageResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="1"
                        Background="#F9FAFB">
                    <Image Source="{Binding Content}" Stretch="Uniform" />
                </Border>
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="{Binding Content}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AudioResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <StackPanel>
                <TextBlock Text="{Binding Name}"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,6,0,14"
                           Text="{Binding Content}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap" />
                <MediaElement Source="{Binding Content}"
                              Height="42"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SurfResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <Border BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Background="#F9FAFB"
                    Padding="16">
                <TextBlock Text="{Binding Content}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}" />
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Title"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Text="{Binding Task.Title, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1"
                           Text="Tags"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Margin="0,10,0,0"
                         Text="{Binding Task.Tags, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2"
                           Text="CreatedOn"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Margin="0,12,20,0"
                           VerticalAlignment="Center"
                           Text="{Binding Task.CreatedOn, StringFormat={}{0:g}}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Text="UpdatedOn"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="2"
                           Grid.Column="3"
                           Margin="0,12,20,0"
                           VerticalAlignment="Center"
                           Text="{Binding Task.UpdatedOn, StringFormat={}{0:g}}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="4"
                           Text="Time Spent"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="2"
                           Grid.Column="5"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding Task.TimeSpent}" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Resources"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Text"
                        Width="90"
                        Command="{Binding AddTextResourceCommand}" />
                <Button Content="Code Snippet"
                        Width="110"
                        Margin="6,0,0,0"
                        Command="{Binding AddCodeResourceCommand}" />
                <Button Content="Image"
                        Width="90"
                        Margin="6,0,0,0"
                        Command="{Binding AddImageResourceCommand}" />
                <Button Content="Audio"
                        Width="90"
                        Margin="6,0,0,0"
                        Command="{Binding AddAudioResourceCommand}" />
                <Button Content="Surf Resource"
                        Width="118"
                        Margin="6,0,0,0"
                        Command="{Binding AddSurfResourceCommand}" />
            </StackPanel>
        </DockPanel>

        <Expander Grid.Row="2"
                  Header="Resources"
                  IsExpanded="True"
                  Margin="0,0,0,12">
            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Padding="10">
                <Grid x:Name="ResourcesGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="420" />
                        <ColumnDefinition x:Name="ResourceSplitterColumn" Width="Auto" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition x:Name="ResourceTreeColumn" Width="260" MinWidth="180" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{StaticResource MutedBorderBrush}"
                            BorderThickness="1"
                            Background="#FFFFFF"
                            Padding="10">
                        <ContentControl Content="{Binding SelectedResource}">
                            <ContentControl.Style>
                                <Style TargetType="{x:Type ContentControl}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource TextResourceTemplate}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedResource.Kind}" Value="{x:Static models:ResourceKind.CodeSnippet}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource CodeResourceTemplate}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedResource.Kind}" Value="{x:Static models:ResourceKind.Image}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource ImageResourceTemplate}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedResource.Kind}" Value="{x:Static models:ResourceKind.Audio}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource AudioResourceTemplate}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedResource.Kind}" Value="{x:Static models:ResourceKind.SurfResource}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource SurfResourceTemplate}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </Border>

                    <GridSplitter x:Name="ResourceGridSplitter"
                                  Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Stretch"
                                  Background="#E5E7EB" />

                    <Button Grid.Column="2"
                            x:Name="ToggleResourceTreeButton"
                            Content=">"
                            Width="26"
                            Margin="3,0"
                            Padding="0"
                            Click="ToggleResourceTreeButton_Click" />

                    <Border Grid.Column="3"
                            x:Name="ResourceTreePanel"
                            BorderBrush="{StaticResource MutedBorderBrush}"
                            BorderThickness="1"
                            Background="#FFFFFF">
                        <TreeView x:Name="ResourceTree"
                                  ItemsSource="{Binding ResourceGroups}"
                                  SelectedItemChanged="ResourceTree_SelectedItemChanged"
                                  BorderThickness="0">
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type models:ResourceGroup}" ItemsSource="{Binding Resources}">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                </HierarchicalDataTemplate>
                                <DataTemplate DataType="{x:Type models:ResourceItem}">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </Border>
                </Grid>
            </Border>
        </Expander>

        <Border Grid.Row="3"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1"
                Padding="10">
            <controls:ActionListControl />
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="84"
                    Content="Close"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
