<Window x:Class="TwoDoThree.Views.TaskDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TwoDoThree.Controls"
        xmlns:converters="clr-namespace:TwoDoThree.Converters"
        xmlns:models="clr-namespace:TwoDoThree.Models"
        Title="Task Detail"
        Icon="../Assets/AppIcon.ico"
        Height="820"
        Width="1120"
        MinHeight="680"
        MinWidth="940"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:StatusDisplayConverter x:Key="StatusDisplayConverter" />

        <Style x:Key="RoundIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#9CA3AF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EFF6FF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DBEAFE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarScrollButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="Surf2ScopeBarVisibilityStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSurf2IntegrationAvailable}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="TextResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <controls:ResourceLinkRichTextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalScrollBarVisibility="Auto"
                                              BorderThickness="0"
                                              Background="#FFFFFF" />
        </DataTemplate>

        <DataTemplate x:Key="CodeResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <controls:CodeSnippetEditor Resource="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="SheetResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <controls:SheetEditor Resource="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="EmailResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding EmailSubject}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="{Binding EmailFrom, StringFormat='From: {0}'}"
                           Foreground="{StaticResource MutedTextBrush}" />
                <TextBlock Grid.Row="2"
                           Margin="0,2,0,10"
                           Text="{Binding EmailReceivedOn, StringFormat='Received: {0:g}'}"
                           Foreground="{StaticResource MutedTextBrush}" />
                <TextBox Grid.Row="3"
                         Text="{Binding Content}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="#FFFFFF" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ImageResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border BorderBrush="{StaticResource MutedBorderBrush}"
                        BorderThickness="1"
                        Background="#F9FAFB">
                    <Image Source="{Binding Content}" Stretch="Uniform" />
                </Border>
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="{Binding Content}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AudioResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <StackPanel>
                <TextBlock Text="{Binding Name}"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,6,0,14"
                           Text="{Binding Content}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap" />
                <MediaElement Source="{Binding Content}"
                              Height="42"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SurfResourceTemplate" DataType="{x:Type models:ResourceItem}">
            <Border BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Background="#F9FAFB"
                    Padding="16">
                <TextBlock Text="{Binding Content}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}" />
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="ResourceSectionRow" Height="3*" MinHeight="180" />
            <RowDefinition x:Name="ResourceActionSplitterRow" Height="Auto" />
            <RowDefinition Height="2*" MinHeight="180" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Title"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Text="{Binding Task.Title, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1"
                           Text="Tags"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center" />
                <controls:TagEditorControl x:Name="TagsEditor"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="5"
                                           Margin="0,10,0,0"
                                           Text="{Binding Task.Tags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           AvailableTags="{Binding AvailableTags}"
                                           ManageTagsRequested="TagsEditor_ManageTagsRequested" />

                <TextBlock Grid.Row="2"
                           Text="Status"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <ComboBox x:Name="TaskStatusComboBox"
                          Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,12,20,0"
                          ItemsSource="{Binding TaskStatusValues}"
                          SelectedItem="{Binding Task.Status, Mode=OneWay}"
                          SelectionChanged="TaskStatusComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource StatusDisplayConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Text="CreatedOn"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="2"
                           Grid.Column="3"
                           Margin="0,12,20,0"
                           VerticalAlignment="Center"
                           Text="{Binding Task.CreatedOn, StringFormat={}{0:g}}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="4"
                           Text="UpdatedOn"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="2"
                           Grid.Column="5"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding Task.UpdatedOn, StringFormat={}{0:g}}" />

                <TextBlock Grid.Row="3"
                           Text="Time Spent"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Margin="0,12,20,0"
                           VerticalAlignment="Center"
                           Cursor="Hand"
                           ToolTip="Double-click to view status periods"
                           MouseLeftButtonDown="TimeSpentTextBlock_MouseLeftButtonDown"
                           Text="{Binding Task.TimeSpent}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="2"
                           Text="Due By"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <DatePicker Grid.Row="3"
                            Grid.Column="3"
                            Margin="0,12,20,0"
                            SelectedDate="{Binding Task.DueBy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4"
                           Text="POCs"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Margin="0,12,0,0"
                         Text="{Binding Task.Pocs, UpdateSourceTrigger=PropertyChanged}" />

            </Grid>
        </Border>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Style="{StaticResource Surf2ScopeBarVisibilityStyle}">
                <TextBlock Text="Surf Scope"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center" />
                <ComboBox Width="260"
                          ItemsSource="{Binding SurfScopes}"
                          SelectedItem="{Binding SelectedSurfScope, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName" />
                <Button Width="30"
                        Height="24"
                        Margin="8,0,0,0"
                        ToolTip="Refresh Surf scopes"
                        Command="{Binding RefreshSurfScopesCommand}">
                    <TextBlock Text="&#xE72C;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13" />
                </Button>
                <TextBlock Width="260"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding Surf2Status}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Text="Resources"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </DockPanel>

        <Expander Grid.Row="2"
                  Header="Resources"
                  IsExpanded="True"
                  Expanded="ResourcesExpander_Expanded"
                  Collapsed="ResourcesExpander_Collapsed"
                  Margin="0,0,0,0">
            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Padding="10">
                <Grid x:Name="ResourcesGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="420" />
                        <ColumnDefinition x:Name="ResourceSplitterColumn" Width="Auto" />
                        <ColumnDefinition x:Name="ResourcePaneColumn" Width="292" MinWidth="32" />
                        <ColumnDefinition Width="36" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{StaticResource MutedBorderBrush}"
                            BorderThickness="1"
                            Background="#FFFFFF"
                            Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <controls:ResourceViewerControl x:Name="SelectedResourceViewer"
                                                            Grid.Column="0"
                                                            Resource="{Binding SelectedResource}" />

                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="4,0,0,0"
                                    BorderBrush="{StaticResource MutedBorderBrush}"
                                    BorderThickness="1,0,0,0">
                                <Grid Width="30">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0"
                                            Style="{StaticResource ToolbarScrollButtonStyle}"
                                            ToolTip="Scroll toolbar up"
                                            Click="InternalToolbarScrollUpButton_Click">
                                        <TextBlock Text="&#xE70E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" />
                                    </Button>

                                    <ScrollViewer x:Name="InternalResourceToolbarScrollViewer"
                                                  Grid.Row="1"
                                                  Margin="0,4"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="False"
                                                  Focusable="False">
                                        <StackPanel Orientation="Vertical">
                                            <Button Style="{StaticResource RoundIconButtonStyle}"
                                                    ToolTip="Expand Resource"
                                                    Click="PopOutResourceButton_Click">
                                                <TextBlock Text="&#xE740;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" />
                                            </Button>
                                            <Button Style="{StaticResource RoundIconButtonStyle}"
                                                    Margin="0,6,0,0"
                                                    ToolTip="Save Resource"
                                                    Command="{Binding SaveSelectedResourceCommand}">
                                                <TextBlock Text="&#xE74E;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" />
                                            </Button>
                                            <Separator Margin="0,6,0,6" />
                                            <StackPanel Orientation="Vertical">
                                                <StackPanel.Style>
                                                    <Style TargetType="{x:Type StackPanel}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedResource.Kind}" Value="{x:Static models:ResourceKind.Text}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                                        ToolTip="Font Family"
                                                        Click="FontFamilyButton_Click">
                                                    <TextBlock Text="Aa"
                                                               FontFamily="Segoe UI"
                                                               FontSize="11" />
                                                </Button>
                                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                                        Margin="0,6,0,0"
                                                        ToolTip="Font Size"
                                                        Click="FontSizeButton_Click">
                                                    <TextBlock Text="A+"
                                                               FontFamily="Segoe UI"
                                                               FontSize="11" />
                                                </Button>
                                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                                        Margin="0,6,0,0"
                                                        ToolTip="Bold"
                                                        Click="BoldButton_Click">
                                                    <TextBlock Text="B"
                                                               FontFamily="Segoe UI"
                                                               FontWeight="Bold"
                                                               FontSize="12" />
                                                </Button>
                                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                                        Margin="0,6,0,0"
                                                        ToolTip="Italic"
                                                        Click="ItalicButton_Click">
                                                    <TextBlock Text="I"
                                                               FontFamily="Segoe UI"
                                                               FontStyle="Italic"
                                                               FontSize="12" />
                                                </Button>
                                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                                        Margin="0,6,0,0"
                                                        ToolTip="Underline"
                                                        Click="UnderlineButton_Click">
                                                    <TextBlock Text="U"
                                                               FontFamily="Segoe UI"
                                                               TextDecorations="Underline"
                                                               FontSize="12" />
                                                </Button>
                                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                                        Margin="0,6,0,0"
                                                        ToolTip="Strikethrough"
                                                        Click="StrikethroughButton_Click">
                                                    <TextBlock Text="S"
                                                               FontFamily="Segoe UI"
                                                       TextDecorations="Strikethrough"
                                                               FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Button Grid.Row="2"
                                            Style="{StaticResource ToolbarScrollButtonStyle}"
                                            ToolTip="Scroll toolbar down"
                                            Click="InternalToolbarScrollDownButton_Click">
                                        <TextBlock Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" />
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter x:Name="ResourceGridSplitter"
                                  Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Stretch"
                                  Background="#E5E7EB" />

                    <Grid Grid.Column="2" x:Name="ResourcePane">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition x:Name="ResourceTreeColumn" Width="*" MinWidth="0" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ToggleResourceTreeButton"
                                Content=">"
                                Width="26"
                                Margin="3,0"
                                Padding="0"
                                VerticalAlignment="Stretch"
                                Click="ToggleResourceTreeButton_Click" />

                        <Border Grid.Column="1"
                                x:Name="ResourceTreePanel"
                                BorderBrush="{StaticResource MutedBorderBrush}"
                                BorderThickness="1"
                                Background="#FFFFFF">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0"
                                         Margin="8"
                                         ToolTip="Filter resources"
                                         Text="{Binding ResourceSearchText, UpdateSourceTrigger=PropertyChanged}" />

                                <TreeView x:Name="ResourceTree"
                                          Grid.Row="1"
                                          ItemsSource="{Binding ResourceGroups}"
                                          MouseDoubleClick="ResourceTree_MouseDoubleClick"
                                          PreviewMouseMove="ResourceTree_PreviewMouseMove"
                                          PreviewMouseRightButtonDown="ResourceTree_PreviewMouseRightButtonDown"
                                          ContextMenuOpening="ResourceTree_ContextMenuOpening"
                                          BorderThickness="0">
                                    <TreeView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem x:Name="RenameResourceMenuItem"
                                                      Header="Rename"
                                                      Click="RenameResourceMenuItem_Click" />
                                        </ContextMenu>
                                    </TreeView.ContextMenu>
                                    <TreeView.Resources>
                                        <HierarchicalDataTemplate DataType="{x:Type models:ResourceGroup}" ItemsSource="{Binding Resources}">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        </HierarchicalDataTemplate>
                                        <DataTemplate DataType="{x:Type models:ResourceItem}">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </TreeView.Resources>
                                </TreeView>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="3"
                          Width="30"
                          HorizontalAlignment="Right"
                          Margin="6,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Style="{StaticResource ToolbarScrollButtonStyle}"
                                ToolTip="Scroll toolbar up"
                                Click="ResourceAddToolbarScrollUpButton_Click">
                            <TextBlock Text="&#xE70E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" />
                        </Button>

                        <ScrollViewer x:Name="ResourceAddToolbarScrollViewer"
                                      Grid.Row="1"
                                      Margin="0,4"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      Focusable="False">
                            <StackPanel Orientation="Vertical">
                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                        ToolTip="Text"
                                        Command="{Binding AddTextResourceCommand}">
                                    <TextBlock Text="&#xE8A5;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                        ToolTip="Sheet"
                                        Margin="0,6,0,0"
                                        Command="{Binding AddSheetResourceCommand}">
                                    <TextBlock Text="&#xE80A;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                        ToolTip="Code Snippet"
                                        Margin="0,6,0,0"
                                        Command="{Binding AddCodeResourceCommand}">
                                    <TextBlock Text="&#xE943;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                        ToolTip="Image"
                                        Margin="0,6,0,0"
                                        Command="{Binding AddImageResourceCommand}">
                                    <TextBlock Text="&#xE91B;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                        ToolTip="Audio"
                                        Margin="0,6,0,0"
                                        Command="{Binding AddAudioResourceCommand}">
                                    <TextBlock Text="&#xE767;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource RoundIconButtonStyle}"
                                        ToolTip="Surf Resource"
                                        Margin="0,6,0,0"
                                        Command="{Binding AddSurfResourceCommand}">
                                    <TextBlock Text="&#xE774;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" />
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Row="2"
                                Style="{StaticResource ToolbarScrollButtonStyle}"
                                ToolTip="Scroll toolbar down"
                                Click="ResourceAddToolbarScrollDownButton_Click">
                            <TextBlock Text="&#xE70D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Expander>

        <GridSplitter x:Name="ResourceActionGridSplitter"
                      Grid.Row="3"
                      Height="8"
                      Margin="0,6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="#D1D5DB"
                      ShowsPreview="True" />

        <Border Grid.Row="4"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource MutedBorderBrush}"
                BorderThickness="1"
                Padding="10">
            <controls:ActionListControl />
        </Border>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="84"
                    Content="Close"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
