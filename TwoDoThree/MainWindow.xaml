<Window x:Class="TwoDoThree.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TwoDoThree.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:models="clr-namespace:TwoDoThree.Models"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="2do3"
        Icon="Assets/AppIcon.ico"
        Height="780"
        Width="1180"
        MinHeight="620"
        MinWidth="920">
    <Window.Resources>
        <converters:StatusDisplayConverter x:Key="StatusDisplayConverter" />
        <converters:TaskStatusToBackgroundConverter x:Key="TaskStatusToBackgroundConverter" />
        <converters:TaskStatusToForegroundConverter x:Key="TaskStatusToForegroundConverter" />

        <Style x:Key="RoundAddButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#16A34A" />
            <Setter Property="BorderBrush" Value="#15803D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#22C55E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#15803D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundOptionsButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#3B82F6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    Width="36"
                    Height="32"
                    Padding="0"
                    ToolTip="Settings"
                    Click="SettingsButton_Click">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE713;"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
        </DockPanel>

        <Expander Grid.Row="1"
                  IsExpanded="{Binding IsEmailSectionExpanded}"
                  Margin="0,0,0,12">
            <Expander.Header>
                <DockPanel LastChildFill="False">
                    <TextBlock Text="Emails"
                               VerticalAlignment="Center" />
                    <TextBox Width="260"
                             Height="24"
                             MinHeight="24"
                             Margin="10,0,0,0"
                             Padding="6,2"
                             VerticalContentAlignment="Center"
                             ToolTip="Filter emails"
                             PreviewMouseDown="HeaderFilterTextBox_PreviewMouseDown"
                             Text="{Binding EmailSearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Margin="20,0,0,0">
                        <TextBlock Text="{Binding EmailSyncStatus}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="420" />
                        <Button Width="28"
                                Height="24"
                                MinHeight="24"
                                Padding="0"
                                Margin="8,0,0,0"
                                ToolTip="Import Email Files"
                                Click="ImportEmailsButton_Click">
                            <TextBlock Text="&#xE8E5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" />
                        </Button>
                        <Button Width="28"
                                Height="24"
                                MinHeight="24"
                                Padding="0"
                                Margin="6,0,0,0"
                                ToolTip="Refresh Outlook"
                                IsEnabled="{Binding CanRefreshEmail}"
                                Click="RefreshEmailsButton_Click">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Expander.Header>
            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Padding="10">
                <Grid Height="260">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" MinWidth="260" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="360" />
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="EmailListBox"
                             Grid.Column="0"
                             ItemsSource="{Binding EmailsView}"
                             SelectedItem="{Binding SelectedEmail}"
                             BorderBrush="{StaticResource MutedBorderBrush}"
                             AllowDrop="True"
                             PreviewDragOver="EmailListBox_PreviewDragOver"
                             Drop="EmailListBox_Drop"
                             PreviewMouseMove="EmailListBox_PreviewMouseMove"
                             MouseDoubleClick="EmailListBox_MouseDoubleClick"
                             PreviewMouseRightButtonDown="EmailListBox_PreviewMouseRightButtonDown">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Import email files"
                                          Click="ImportEmailFilesMenuItem_Click" />
                                <Separator />
                                <MenuItem Header="Create task from email"
                                          Click="CreateTaskFromEmailMenuItem_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Subject}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AssociatedTaskSummary}"
                                               FontSize="11"
                                               FontStyle="Italic"
                                               Foreground="#2563EB"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding AssociatedTaskSummary}">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAssociatedTasks}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding From}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Preview}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               MaxHeight="38" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <GridSplitter Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Stretch"
                                  Background="#E5E7EB" />

                    <Border Grid.Column="2"
                            Margin="10,0,0,0"
                            Padding="12"
                            BorderBrush="{StaticResource MutedBorderBrush}"
                            BorderThickness="1"
                            Background="#FFFFFF">
                        <Grid DataContext="{Binding SelectedEmail}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding Subject, TargetNullValue='No email selected'}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,6,0,0"
                                       Text="{Binding From}"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,2,0,8"
                                       Text="{Binding ReceivedOn, StringFormat='Received: {0:g}'}"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding Body}"
                                           TextWrapping="Wrap"
                                           LineHeight="20" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Expander>

        <Expander Grid.Row="2"
                  IsExpanded="{Binding IsTaskSectionExpanded}">
            <Expander.Header>
                <DockPanel LastChildFill="False">
                    <TextBlock Text="Tasks"
                               VerticalAlignment="Center" />
                    <TextBox Width="260"
                             Height="24"
                             MinHeight="24"
                             Margin="10,0,0,0"
                             Padding="6,2"
                             VerticalContentAlignment="Center"
                             ToolTip="Filter tasks"
                             PreviewMouseDown="HeaderFilterTextBox_PreviewMouseDown"
                             Text="{Binding TaskSearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Margin="20,0,0,0">
                        <TextBlock Text="{Binding TaskPersistenceStatus}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="320" />
                        <TextBlock Text="{Binding TaskEmailFilterSummary}"
                                   Foreground="#2563EB"
                                   FontSize="12"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="420"
                                   Margin="12,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTaskEmailFilter}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Width="24"
                                Height="24"
                                MinHeight="24"
                                Margin="8,0,0,0"
                                Padding="0"
                                ToolTip="Clear email filter"
                                Click="ClearTaskEmailFilterButton_Click">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTaskEmailFilter}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Expander.Header>
            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <Button x:Name="TasksListOptionsButton"
                                    Style="{StaticResource RoundOptionsButtonStyle}"
                                    ToolTip="Task List Options"
                                    Margin="0,2,8,2"
                                    Click="TasksListOptionsButton_Click">
                                <TextBlock Text="&#xE700;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" />
                            </Button>
                            <Button Style="{StaticResource RoundAddButtonStyle}"
                                    ToolTip="Add Task"
                                    Click="AddTaskButton_Click">
                                <TextBlock Text="&#xE710;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" />
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="TasksGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding TasksView}"
                              SelectedItem="{Binding SelectedTask}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AllowDrop="True"
                              PreviewDragOver="TasksGrid_PreviewDragOver"
                              Drop="TasksGrid_Drop"
                              PreviewMouseRightButtonDown="TasksGrid_PreviewMouseRightButtonDown"
                              MouseDoubleClick="TasksGrid_MouseDoubleClick"
                              AlternatingRowBackground="{x:Null}"
                              RowHeaderWidth="0">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Peek"
                                          Click="PeekTaskMenuItem_Click" />
                                <Separator />
                                <MenuItem Header="Status">
                                    <MenuItem Header="Inactive"
                                              Tag="{x:Static models:TaskStatus.Inactive}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="Active"
                                              Tag="{x:Static models:TaskStatus.Active}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="In-Progress"
                                              Tag="{x:Static models:TaskStatus.InProgress}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="On Hold"
                                              Tag="{x:Static models:TaskStatus.OnHold}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="Blocked"
                                              Tag="{x:Static models:TaskStatus.Blocked}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="Complete"
                                              Tag="{x:Static models:TaskStatus.Complete}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="Cancelled"
                                              Tag="{x:Static models:TaskStatus.Cancelled}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="AllowDrop" Value="True" />
                                <Setter Property="Background" Value="{Binding Status, Converter={StaticResource TaskStatusToBackgroundConverter}}" />
                                <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource TaskStatusToForegroundConverter}}" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="BorderBrush" Value="#1D4ED8" />
                                        <Setter Property="BorderThickness" Value="1" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="{x:Type DataGridCell}">
                                <Setter Property="Background" Value="{Binding Status, Converter={StaticResource TaskStatusToBackgroundConverter}}" />
                                <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource TaskStatusToForegroundConverter}}" />
                                <Setter Property="BorderBrush" Value="#F3F4F6" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter Margin="6,3"
                                                                  VerticalAlignment="Center"
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="BorderBrush" Value="#1D4ED8" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="70" Binding="{Binding Id}" />
                            <DataGridTextColumn Header="Title" Width="2*" Binding="{Binding Title}" />
                            <DataGridTextColumn Header="Tags" Width="*" Binding="{Binding Tags}" />
                            <DataGridTextColumn Header="Status" Width="120" Binding="{Binding Status, Converter={StaticResource StatusDisplayConverter}}" />
                            <DataGridTextColumn Header="CreatedOn" Width="150" Binding="{Binding CreatedOn, StringFormat={}{0:g}}" />
                            <DataGridTextColumn Header="UpdatedOn" Width="150" Binding="{Binding UpdatedOn, StringFormat={}{0:g}}" />
                            <DataGridTextColumn Header="Time Spent" Width="120" Binding="{Binding TimeSpent}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Expander>
    </Grid>
</Window>
