<Window x:Class="TwoDoThree.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TwoDoThree.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:models="clr-namespace:TwoDoThree.Models"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="2do3"
        Height="780"
        Width="1180"
        MinHeight="620"
        MinWidth="920">
    <Window.Resources>
        <converters:StatusDisplayConverter x:Key="StatusDisplayConverter" />
        <converters:TaskStatusToBackgroundConverter x:Key="TaskStatusToBackgroundConverter" />
        <converters:TaskStatusToForegroundConverter x:Key="TaskStatusToForegroundConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <Label Content="Search:"
                       Target="{Binding ElementName=SearchBox}"
                       VerticalAlignment="Center"
                       Padding="0,0,8,0" />
                <TextBox x:Name="SearchBox"
                         Width="360"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Width="36"
                    Height="32"
                    Padding="0"
                    ToolTip="Settings"
                    Click="SettingsButton_Click">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE713;"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
        </DockPanel>

        <Expander Grid.Row="1"
                  Header="Email"
                  IsExpanded="{Binding IsEmailSectionExpanded}"
                  Margin="0,0,0,12">
            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Padding="10">
                <Grid Height="260">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" MinWidth="260" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="360" />
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="EmailListBox"
                             Grid.Column="0"
                             ItemsSource="{Binding EmailsView}"
                             SelectedItem="{Binding SelectedEmail}"
                             BorderBrush="{StaticResource MutedBorderBrush}"
                             PreviewMouseRightButtonDown="EmailListBox_PreviewMouseRightButtonDown">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Create task from email"
                                          Click="CreateTaskFromEmailMenuItem_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Subject}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding From}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Preview}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               MaxHeight="38" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <GridSplitter Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Stretch"
                                  Background="#E5E7EB" />

                    <Border Grid.Column="2"
                            Margin="10,0,0,0"
                            Padding="12"
                            BorderBrush="{StaticResource MutedBorderBrush}"
                            BorderThickness="1"
                            Background="#FFFFFF">
                        <Grid DataContext="{Binding SelectedEmail}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding Subject, TargetNullValue='No email selected'}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,6,0,0"
                                       Text="{Binding From}"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,2,0,8"
                                       Text="{Binding ReceivedOn, StringFormat='Received: {0:g}'}"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding Body}"
                                           TextWrapping="Wrap"
                                           LineHeight="20" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Expander>

        <Expander Grid.Row="2"
                  Header="Tasks"
                  IsExpanded="{Binding IsTaskSectionExpanded}">
            <Border Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource MutedBorderBrush}"
                    BorderThickness="1"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right"
                                Width="90"
                                Content="Add Task"
                                Click="AddTaskButton_Click" />
                    </DockPanel>

                    <DataGrid x:Name="TasksGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding TasksView}"
                              SelectedItem="{Binding SelectedTask}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              PreviewMouseRightButtonDown="TasksGrid_PreviewMouseRightButtonDown"
                              MouseDoubleClick="TasksGrid_MouseDoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Peek"
                                          Click="PeekTaskMenuItem_Click" />
                                <Separator />
                                <MenuItem Header="Status">
                                    <MenuItem Header="Inactive"
                                              Tag="{x:Static models:TaskStatus.Inactive}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="Active"
                                              Tag="{x:Static models:TaskStatus.Active}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="In-Progress"
                                              Tag="{x:Static models:TaskStatus.InProgress}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="On Hold"
                                              Tag="{x:Static models:TaskStatus.OnHold}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="Blocked"
                                              Tag="{x:Static models:TaskStatus.Blocked}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="Complete"
                                              Tag="{x:Static models:TaskStatus.Complete}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                    <MenuItem Header="Cancelled"
                                              Tag="{x:Static models:TaskStatus.Cancelled}"
                                              Click="SetTaskStatusMenuItem_Click" />
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="{Binding Status, Converter={StaticResource TaskStatusToBackgroundConverter}}" />
                                <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource TaskStatusToForegroundConverter}}" />
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="70" Binding="{Binding Id}" />
                            <DataGridTextColumn Header="Title" Width="2*" Binding="{Binding Title}" />
                            <DataGridTextColumn Header="Tags" Width="*" Binding="{Binding Tags}" />
                            <DataGridTextColumn Header="Status" Width="120" Binding="{Binding Status, Converter={StaticResource StatusDisplayConverter}}" />
                            <DataGridTextColumn Header="CreatedOn" Width="150" Binding="{Binding CreatedOn, StringFormat={}{0:g}}" />
                            <DataGridTextColumn Header="UpdatedOn" Width="150" Binding="{Binding UpdatedOn, StringFormat={}{0:g}}" />
                            <DataGridTextColumn Header="Time Spent" Width="120" Binding="{Binding TimeSpent}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Expander>
    </Grid>
</Window>
