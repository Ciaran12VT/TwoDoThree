<UserControl x:Class="TwoDoThree.Controls.SheetEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   LastChildFill="False"
                   Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Right">
                <Button Width="30"
                        Height="30"
                        Padding="0"
                        ToolTip="Add row"
                        Click="AddRowButton_Click">
                    <TextBlock Text="&#xE710;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13" />
                </Button>
                <Button Width="30"
                        Height="30"
                        Padding="0"
                        Margin="6,0,0,0"
                        ToolTip="Add column"
                        Click="AddColumnButton_Click">
                    <TextBlock Text="&#xE8A9;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13" />
                </Button>
                <Button Width="30"
                        Height="30"
                        Padding="0"
                        Margin="6,0,0,0"
                        ToolTip="Delete selected row"
                        Click="DeleteRowButton_Click">
                    <TextBlock Text="&#xE74D;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13" />
                </Button>
                <Button Width="30"
                        Height="30"
                        Padding="0"
                        Margin="6,0,0,0"
                        ToolTip="Delete current column"
                        Click="DeleteColumnButton_Click">
                    <TextBlock Text="&#xE75C;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13" />
                </Button>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="SheetGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  HeadersVisibility="All"
                  GridLinesVisibility="All"
                  AutoGeneratingColumn="SheetGrid_AutoGeneratingColumn"
                  CurrentCellChanged="SheetGrid_CurrentCellChanged"
                  PreviewKeyDown="SheetGrid_PreviewKeyDown"
                  RowEditEnding="SheetGrid_RowEditEnding" />
    </Grid>
</UserControl>
