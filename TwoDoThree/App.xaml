<Application x:Class="TwoDoThree.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F4F6" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedBorderBrush" Color="#D1D5DB" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#4B5563" />

        <Style TargetType="{x:Type Window}">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderBrush" Value="{StaticResource MutedBorderBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="BorderBrush" Value="{StaticResource MutedBorderBrush}" />
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MutedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB" />
        </Style>
    </Application.Resources>
</Application>
